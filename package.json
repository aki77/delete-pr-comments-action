{
  "name": "delete-pr-comments-action",
  "version": "3.2.0",
  "private": true,
  "description": "Delete PR review comments by any conditions.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "format": "biome format --write .",
    "format-check": "biome format --check .",
    "lint": "biome check .",
    "lint-fix": "biome check --write .",
    "package": "rimraf ./dist && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "all": "npm run build && npm run format && npm run lint && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aki77/delete-pr-comments-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "aki77",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/node": "^24.12.3",
    "js-yaml": "^4.1.1",
    "rimraf": "^6.0.0",
    "rollup": "^4.61.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@9.4.0"
}
